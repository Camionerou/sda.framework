# Template para /etc/sda-indexer.env en srv-ia-01 producción.
# Copiar este archivo a /etc/sda-indexer.env y llenar los <PLACEHOLDERS>.
# chmod 600 después de editar (sólo root debe poder leer el bearer y las keys).

# === Environment ===
SDA_ENV=production
SDA_LOG_LEVEL=INFO

# === Supabase REMOTE (producción) ===
SDA_SUPABASE_URL=https://anfawvxfepowsudlffnl.supabase.co

# Service role key — Supabase dashboard → Settings → API → service_role (eyJ...)
SDA_SUPABASE_SERVICE_KEY=<COPIAR_SERVICE_ROLE_KEY_REMOTO>

# Postgres connection string del Supabase pooler:
# Supabase dashboard → Settings → Database → Connection string → URI (Session pooler, port 5432)
# Formato típico: postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# IMPORTANTE: NO usar Transaction pooler (port 6543) — no soporta LISTEN/NOTIFY que SettingsClient necesita.
SDA_DB_DSN=postgresql://postgres.anfawvxfepowsudlffnl:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres

# === DeepSeek ===
SDA_DEEPSEEK_API_KEY=sk-<DEEPSEEK_KEY>
SDA_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Bearer compartido pg_net ↔ srv-ia-01 ===
# Generar con: openssl rand -hex 32
# Este MISMO valor va a Vault remoto como secret 'srv_ia_01_secret'.
SDA_SRV_IA_01_SECRET=<GENERAR_CON_OPENSSL_RAND_HEX_32>

# === Pool (production tuning) ===
SDA_DB_POOL_MIN_SIZE=4
SDA_DB_POOL_MAX_SIZE=30
