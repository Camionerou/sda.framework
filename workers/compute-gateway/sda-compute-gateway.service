[Unit]
Description=SDA Compute Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/sda-compute-gateway
EnvironmentFile=%h/sda-compute-gateway/.env
ExecStart=/usr/bin/env node server.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
