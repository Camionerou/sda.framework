[Unit]
Description=SDA Tree Indexer FastAPI Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/sda-tree-indexer-python
EnvironmentFile=%h/sda-tree-indexer-python/.env
ExecStart=/usr/bin/env bash -lc 'exec .venv/bin/uvicorn app.main:app --host 0.0.0.0 --port "${PORT:-8790}"'
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
